<!-- Promo & Grow: Trust Bar (below hero) -->
<section class="png-section-white" style="padding-top: 0;">
  <div class="page-width">
    <div class="png-trust-bar">
      <div class="png-trust-bar__item">
        <span class="png-trust-bar__stars" aria-label="4.8 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span>4.8 &middot; 19 reviews</span>
      </div>
      <span class="png-trust-bar__divider" aria-hidden="true">|</span>
      <div class="png-trust-bar__item">
        <span>20+ years in production</span>
      </div>
      <span class="png-trust-bar__divider" aria-hidden="true">|</span>
      <div class="png-trust-bar__item">
        <span>Made in the USA</span>
      </div>
    </div>
  </div>
</section>

