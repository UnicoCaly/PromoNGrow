<!-- Promo & Grow: Artwork Help Card -->
<section class="png-section-white" style="padding-top: 0;">
  <div class="page-width">
    <div class="png-artwork-help">
      <div class="png-artwork-help__icon" aria-hidden="true">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="12" y1="18" x2="12" y2="12"></line>
          <line x1="9" y1="15" x2="15" y2="15"></line>
        </svg>
      </div>
      <div class="png-artwork-help__content">
        <h3 class="png-artwork-help__title">{{ section.settings.heading | default: 'Need help with artwork?' }}</h3>
        <p class="png-artwork-help__text">{{ section.settings.text | default: 'Design not included — but we make it easy. Use our free Canva templates and AI prompt guides to create print-ready files in minutes.' }}</p>
      </div>
      <div class="png-artwork-help__action">
        <a href="{{ section.settings.link | default: '/pages/contact' }}" class="png-section-header__link">
          {{ section.settings.link_label | default: 'Design resources' }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Artwork Help",
  "class": "png-artwork-help-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Need help with artwork?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Design not included — but we make it easy. Use our free Canva templates and AI prompt guides to create print-ready files in minutes."
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Design resources"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Artwork Help"
    }
  ]
}
{% endschema %}
