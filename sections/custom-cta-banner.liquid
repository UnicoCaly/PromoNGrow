<!-- Promo & Grow: CTA Banner -->
<div class="png-cta-banner-wrapper">
  <div class="page-width">
    <div class="png-cta-banner">
      <div class="png-cta-banner__content">
        <h2 class="png-cta-banner__title">{{ section.settings.heading | default: 'Ready to stand out?' }}</h2>
        <p class="png-cta-banner__subtitle">{{ section.settings.subtext | default: '10% off your first order. No gimmicks, no countdown timers.' }}</p>
      </div>
      <div class="png-cta-banner__actions">
        {%- if section.settings.primary_url != blank -%}
          <a href="{{ section.settings.primary_url }}" class="png-btn-primary">
            {{ section.settings.primary_label | default: 'Shop bundles' }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_url != blank or section.settings.secondary_label != blank -%}
          <a href="{{ section.settings.secondary_url | default: 'tel:8448833308' }}" class="png-btn-ghost--light">
            {{ section.settings.secondary_label | default: 'Call (844) 883-3308' }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CTA Banner",
  "class": "png-cta-banner-section",
  "enabled_on": {
    "groups": ["footer"],
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Ready to stand out?"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "10% off your first order. No gimmicks, no countdown timers."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop bundles"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Call (844) 883-3308"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "CTA Banner"
    }
  ]
}
{% endschema %}
