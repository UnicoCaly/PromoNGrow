<!-- Promo & Grow: Hero Section -->
<section class="png-hero png-section-white">
  <div class="page-width">
    <div class="png-hero__grid">
      <div class="png-hero__content">
        <span class="png-eyebrow">{{ section.settings.eyebrow | default: 'Custom event displays' }}</span>
        <h1 class="png-hero__heading">{{ section.settings.heading | default: 'Your brand, built to show up.' }}</h1>
        <p class="png-hero__subtext">{{ section.settings.subtext | default: 'Custom tents, backdrops, flags, and signage — produced and delivered nationwide in 5 business days.' }}</p>
        <div class="png-hero__actions">
          <a href="{{ section.settings.primary_url | default: '/collections/bundles' }}" class="png-hero__btn-primary">
            {{ section.settings.primary_label | default: 'Shop bundles' }}
          </a>
          <a href="{{ section.settings.secondary_url | default: '/pages/contact' }}" class="png-hero__link-cta">
            {{ section.settings.secondary_label | default: 'Get a quote' }} &rarr;
          </a>
        </div>
      </div>
      <div class="png-hero__image">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag:
              class: 'png-hero__img',
              loading: 'eager',
              sizes: '(min-width: 750px) 40vw, 100vw',
              widths: '400, 600, 800'
          }}
        {%- else -%}
          <div class="png-hero__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'png-hero__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "class": "png-hero-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Custom event displays"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your brand, built to show up."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Custom tents, backdrops, flags, and signage — produced and delivered nationwide in 5 business days."
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop bundles"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary link label",
      "default": "Get a quote"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary link URL"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
