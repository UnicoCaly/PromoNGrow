<!-- Promo & Grow: Trust Strip (replaces Dawn announcement bar) -->
<div class="png-ab" role="banner" aria-label="Trust badges">
  <div class="png-ab__inner">
    <!-- Desktop: full version -->
    <div class="png-ab__desktop">
      <span class="png-ab__stars" aria-label="4.8 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="png-ab__text">4.8 rating</span>
      <span class="png-ab__divider" aria-hidden="true">|</span>
      <span class="png-ab__dot" aria-hidden="true"></span>
      <span class="png-ab__text">5-day delivery</span>
      <span class="png-ab__divider" aria-hidden="true">|</span>
      <span class="png-ab__text">Made in the USA</span>
      <span class="png-ab__divider" aria-hidden="true">|</span>
      <span class="png-ab__text">Free proof on every order</span>
    </div>
    <!-- Mobile: condensed version -->
    <div class="png-ab__mobile">
      <span class="png-ab__stars" aria-label="4.8 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span class="png-ab__text">4.8</span>
      <span class="png-ab__text">&middot;</span>
      <span class="png-ab__text">5-day delivery</span>
      <span class="png-ab__text">&middot;</span>
      <span class="png-ab__text">Made in USA</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.announcement-bar.name",
  "class": "png-announcement-bar-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [],
  "presets": [
    {
      "name": "t:sections.announcement-bar.presets.name"
    }
  ]
}
{% endschema %}
