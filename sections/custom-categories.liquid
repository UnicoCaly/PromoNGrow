<!-- Promo & Grow: Category Grid -->
<section class="png-section-white">
  <div class="page-width">
    <div class="png-section-header">
      <h2 class="png-section-header__title">{{ section.settings.heading | default: 'Shop by category' }}</h2>
      {%- if section.settings.view_all_url != blank -%}
        <a href="{{ section.settings.view_all_url }}" class="png-section-header__link">View all</a>
      {%- endif -%}
    </div>

    <div class="png-category-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="png-category-card" {{ block.shopify_attributes }}>
          <div class="png-category-card__image-wrapper">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  class: 'png-category-card__image',
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 20vw, 50vw',
                  widths: '300, 400, 600'
              }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'png-category-card__image' }}
            {%- endif -%}
          </div>
          <p class="png-category-card__title">{{ block.settings.title }}</p>
          {%- if block.settings.subtitle != blank -%}
            <p class="png-category-card__subtitle{% if block.settings.highlight_subtitle %} png-category-card__subtitle--savings{% endif %}">
              {{ block.settings.subtitle }}
            </p>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid",
  "class": "png-categories-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by category"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "checkbox",
          "id": "highlight_subtitle",
          "label": "Highlight subtitle (green)",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category", "settings": { "title": "Bundles", "subtitle": "Save 15%+ →", "highlight_subtitle": true } },
        { "type": "category", "settings": { "title": "Tents", "subtitle": "From $495" } },
        { "type": "category", "settings": { "title": "Displays", "subtitle": "From $295" } },
        { "type": "category", "settings": { "title": "Accessories", "subtitle": "From $95" } },
        { "type": "category", "settings": { "title": "Wraps", "subtitle": "From $195" } }
      ]
    }
  ]
}
{% endschema %}
