{% comment %}
  Promo & Grow: 5-item navigation with benefit subtitles.
  Subtitles are configurable via the Header section schema in theme customizer.
{% endcomment %}

<nav class="header__inline-menu">
  <ul class="png-nav list-menu list-menu--inline" role="list">
    <!-- 1. Bundles -->
    <li>
      <a href="/collections/bundles" class="png-nav-link header__menu-item list-menu__item link link--text focus-inset">
        <span class="png-nav-item-wrap">
          <span class="png-nav-title">Bundles</span>
          <span class="png-nav-subtitle png-nav-subtitle--copper">{{ section.settings.nav_subtitle_1 | default: 'Save 15%+' }}</span>
        </span>
      </a>
    </li>
    <!-- 2. Tents -->
    <li>
      <a href="/collections/tents-canopies" class="png-nav-link header__menu-item list-menu__item link link--text focus-inset">
        <span class="png-nav-item-wrap">
          <span class="png-nav-title">Tents</span>
          <span class="png-nav-subtitle">{{ section.settings.nav_subtitle_2 | default: 'Free 3D preview' }}</span>
        </span>
      </a>
    </li>
    <!-- 3. Displays -->
    <li>
      <a href="/collections/backdrop-display" class="png-nav-link header__menu-item list-menu__item link link--text focus-inset">
        <span class="png-nav-item-wrap">
          <span class="png-nav-title">Displays</span>
          <span class="png-nav-subtitle">{{ section.settings.nav_subtitle_3 | default: 'SEG + popup' }}</span>
        </span>
      </a>
    </li>
    <!-- 4. Flags -->
    <li>
      <a href="/collections/accessories" class="png-nav-link header__menu-item list-menu__item link link--text focus-inset">
        <span class="png-nav-item-wrap">
          <span class="png-nav-title">Flags</span>
          <span class="png-nav-subtitle">{{ section.settings.nav_subtitle_4 | default: '5 styles · small → large' }}</span>
        </span>
      </a>
    </li>
    <!-- 5. Wraps -->
    <li>
      <a href="/collections/wraps" class="png-nav-link header__menu-item list-menu__item link link--text focus-inset">
        <span class="png-nav-item-wrap">
          <span class="png-nav-title">Wraps</span>
          <span class="png-nav-subtitle">{{ section.settings.nav_subtitle_5 | default: 'Walls + backdrops' }}</span>
        </span>
      </a>
    </li>
  </ul>
</nav>
