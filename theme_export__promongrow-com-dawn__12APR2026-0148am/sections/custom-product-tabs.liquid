<!-- Promo & Grow: Product Tabs (Below the Fold) -->
<section class="png-section-white">
  <div class="page-width">
    <!-- Tab Navigation -->
    <div class="png-tabs" role="tablist">
      {%- for block in section.blocks -%}
        <button
          class="png-tabs__tab{% if forloop.first %} png-tabs__tab--active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-controls="tab-panel-{{ block.id }}"
          id="tab-{{ block.id }}"
          data-tab-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          {{ block.settings.tab_title }}
        </button>
      {%- endfor -%}
    </div>

    <!-- Tab Panels -->
    {%- for block in section.blocks -%}
      <div
        class="png-tabs__panel{% if forloop.first %} png-tabs__panel--active{% endif %}"
        role="tabpanel"
        id="tab-panel-{{ block.id }}"
        aria-labelledby="tab-{{ block.id }}"
        data-tab-index="{{ forloop.index0 }}"
        {% unless forloop.first %}hidden{% endunless %}
      >
        <div class="png-tabs__content rte">
          {{ block.settings.tab_content }}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.png-tabs__tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        var index = this.getAttribute('data-tab-index');
        var tablist = this.closest('.png-section-white');
        tablist.querySelectorAll('.png-tabs__tab').forEach(function (t) {
          t.classList.remove('png-tabs__tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tablist.querySelectorAll('.png-tabs__panel').forEach(function (p) {
          p.classList.remove('png-tabs__panel--active');
          p.hidden = true;
        });
        this.classList.add('png-tabs__tab--active');
        this.setAttribute('aria-selected', 'true');
        var panel = tablist.querySelector('.png-tabs__panel[data-tab-index="' + index + '"]');
        if (panel) {
          panel.classList.add('png-tabs__panel--active');
          panel.hidden = false;
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Tabs",
  "class": "png-product-tabs-section",
  "max_blocks": 6,
  "settings": [],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Tab title",
          "default": "Details"
        },
        {
          "type": "richtext",
          "id": "tab_content",
          "label": "Tab content",
          "default": "<p>Tab content goes here.</p>"
        }
      ]
    }
  ],
  "presets": [
