<!-- Promo & Grow: Trust Strip -->
<div class="png-trust-strip" role="banner" aria-label="Trust badges">
  <div class="page-width png-trust-strip__inner">
    <div class="png-trust-strip__item">
      <span class="png-trust-strip__stars" aria-label="4.8 out of 5 stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span>4.8 rating</span>
    </div>
    <span class="png-trust-strip__divider" aria-hidden="true">|</span>
    <div class="png-trust-strip__item">
      <span class="png-trust-strip__dot" aria-hidden="true"></span>
      <span>5-day delivery</span>
    </div>
    <span class="png-trust-strip__divider" aria-hidden="true">|</span>
    <div class="png-trust-strip__item">
      <span>Made in the USA</span>
    </div>
    <span class="png-trust-strip__divider" aria-hidden="true">|</span>
    <div class="png-trust-strip__item">
      <span>Free proof on every order</span>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust Strip",
  "class": "png-trust-strip-section",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Trust Strip"
    }
  ]
}
{% endschema %}
