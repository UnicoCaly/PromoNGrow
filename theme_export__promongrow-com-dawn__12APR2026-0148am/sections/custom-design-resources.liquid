<!-- Promo & Grow: Design Resources Page -->

<!-- 1. Hero (centered) -->
<section class="png-dr-hero png-section-white">
  <div class="page-width png-dr-hero__inner">
    <span class="png-eyebrow">DESIGN RESOURCES</span>
    <h1 class="png-dr-hero__heading">We don't do the design. We make it easy.</h1>
    <p class="png-dr-hero__subtext">Free templates, guides, and AI prompts to help you create print-ready artwork in minutes. Every order is proofed before production.</p>
  </div>
</section>

<!-- 2. Three-step process -->
<section class="png-section-white" style="padding-top: 0;">
  <div class="page-width">
    <div class="png-dr-steps-panel">
      <div class="png-steps">
        <div class="png-step">
          <div class="png-step__number">1</div>
          <h3 class="png-step__title">Download template</h3>
          <p class="png-step__description">Pre-sized to your product with bleed guides</p>
        </div>
        <div class="png-step__arrow" aria-hidden="true">&rarr;</div>
        <div class="png-step">
          <div class="png-step__number">2</div>
          <h3 class="png-step__title">Add your design</h3>
          <p class="png-step__description">Use Canva, Illustrator, or our AI prompts</p>
        </div>
        <div class="png-step__arrow" aria-hidden="true">&rarr;</div>
        <div class="png-step">
          <div class="png-step__number png-step__number--accent">3</div>
          <h3 class="png-step__title">Upload and order</h3>
          <p class="png-step__description">We proof before production. You approve, we print.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- 3. Template download grid (3 hardcoded cards) -->
<section class="png-section-white">
  <div class="page-width">
    <div class="png-section-header">
      <h2 class="png-section-header__title">Download templates</h2>
      <span class="png-section-header__meta">PDF / AI format</span>
    </div>
    <div class="png-dr-templates-grid">

      <!-- Card 1: 10'x10' Tent Canopy -->
      <div class="png-dr-template-card">
        <div class="png-dr-template-card__preview">
          <div class="png-dr-template-card__placeholder">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
        </div>
        <h3 class="png-dr-template-card__name">10'x10' Tent Canopy</h3>
        <p class="png-dr-template-card__dims">120" x 120" + 0.125" bleed</p>
        <div class="png-dr-template-card__actions">
          <a href="#" class="png-dr-dl-btn">PDF</a>
          <a href="#" class="png-dr-dl-btn">AI</a>
        </div>
      </div>

      <!-- Card 2: 6ft Table Throw -->
      <div class="png-dr-template-card">
        <div class="png-dr-template-card__preview">
          <div class="png-dr-template-card__placeholder">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
        </div>
        <h3 class="png-dr-template-card__name">6ft Table Throw</h3>
        <p class="png-dr-template-card__dims">132" x 90.5" + 0.125" bleed</p>
        <div class="png-dr-template-card__actions">
          <a href="#" class="png-dr-dl-btn">PDF</a>
          <a href="#" class="png-dr-dl-btn">AI</a>
        </div>
      </div>

      <!-- Card 3: Teardrop Flag -->
      <div class="png-dr-template-card">
        <div class="png-dr-template-card__preview">
          <div class="png-dr-template-card__placeholder">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
        </div>
        <h3 class="png-dr-template-card__name">Teardrop Flag</h3>
        <p class="png-dr-template-card__dims">30" x 68" + 0.125" bleed</p>
        <div class="png-dr-template-card__actions">
          <a href="#" class="png-dr-dl-btn">PDF</a>
          <a href="#" class="png-dr-dl-btn">AI</a>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- 4. File requirements (2x2 grid) -->
<section class="png-section-white">
  <div class="page-width">
    <div class="png-section-header">
      <h2 class="png-section-header__title">File requirements</h2>
    </div>
    <div class="png-dr-reqs-grid">
      <div class="png-dr-req-card">
        <h3 class="png-dr-req-card__title">Accepted formats</h3>
        <p class="png-dr-req-card__text">PDF, AI, EPS, PNG, PSD, JPG</p>
      </div>
      <div class="png-dr-req-card">
        <h3 class="png-dr-req-card__title">Resolution</h3>
        <p class="png-dr-req-card__text">300 DPI minimum (150 DPI for items over 48")</p>
      </div>
      <div class="png-dr-req-card">
        <h3 class="png-dr-req-card__title">Color space</h3>
        <p class="png-dr-req-card__text">CMYK preferred. RGB accepted (we convert)</p>
      </div>
      <div class="png-dr-req-card">
        <h3 class="png-dr-req-card__title">Bleed</h3>
        <p class="png-dr-req-card__text">0.125" on all sides. Keep text 0.25" from trim edge.</p>
      </div>
    </div>
  </div>
</section>

<!-- 5. AI prompt guide (3 expandable cards) -->
<section class="png-section-white">
  <div class="page-width">
    <div class="png-dr-prompts-header">
      <h2 class="png-section-header__title">AI prompt guide</h2>
      <p class="png-section-header__meta">Copy these into ChatGPT or Canva AI to generate event-ready graphics.</p>
    </div>
    <div class="png-dr-prompts">

      <!-- Prompt 1: Tent canopy -->
      <details class="png-dr-prompt-card">
        <summary class="png-dr-prompt-card__header">
          <span class="png-dr-prompt-card__title">Tent canopy design</span>
          <span class="png-dr-prompt-card__toggle" aria-hidden="true">+</span>
        </summary>
        <div class="png-dr-prompt-card__body">
          <pre class="png-dr-prompt-card__text">Design a full-color tent canopy for [BUSINESS NAME]. The business is [INDUSTRY]. Brand colors are [COLOR 1] and [COLOR 2]. Include the logo centered on the canopy top with the business name and tagline "[TAGLINE]" below it. Style: clean, professional, easy to read from 20 feet away. Output as a high-resolution PNG at 300 DPI, 120 inches x 120 inches, CMYK color space.</pre>
          <button class="png-dr-copy-btn" type="button">Copy prompt</button>
        </div>
      </details>

      <!-- Prompt 2: Trade show backdrop -->
      <details class="png-dr-prompt-card">
        <summary class="png-dr-prompt-card__header">
          <span class="png-dr-prompt-card__title">Trade show backdrop</span>
          <span class="png-dr-prompt-card__toggle" aria-hidden="true">+</span>
        </summary>
        <div class="png-dr-prompt-card__body">
          <pre class="png-dr-prompt-card__text">Design a trade show backdrop for [BUSINESS NAME]. Industry: [INDUSTRY]. Brand colors: [COLOR 1], [COLOR 2]. Include: large logo centered, tagline below, 3 key selling points or services listed. Style: professional, clean, bold text readable from 10 feet. Output: high-resolution PNG, 300 DPI, 96 x 96 inches, CMYK.</pre>
          <button class="png-dr-copy-btn" type="button">Copy prompt</button>
        </div>
      </details>

      <!-- Prompt 3: Table throw -->
      <details class="png-dr-prompt-card">
        <summary class="png-dr-prompt-card__header">
          <span class="png-dr-prompt-card__title">Table throw layout</span>
          <span class="png-dr-prompt-card__toggle" aria-hidden="true">+</span>
        </summary>
        <div class="png-dr-prompt-card__body">
          <pre class="png-dr-prompt-card__text">Design a 6ft table throw for [BUSINESS NAME]. Industry: [INDUSTRY]. Brand colors: [COLOR 1], [COLOR 2]. Front panel: large centered logo with tagline. Side panels: website URL and phone number. Style: clean, minimal, professional. Output: high-resolution PNG, 300 DPI, 132 x 90.5 inches, CMYK.</pre>
          <button class="png-dr-copy-btn" type="button">Copy prompt</button>
        </div>
      </details>

    </div>
  </div>
</section>

<!-- 6. Bottom CTA (navy band) -->
<section class="png-section-white" style="padding-top: 16px;">
  <div class="page-width">
    <div class="png-cta-banner">
      <div class="png-cta-banner__content">
        <h2 class="png-cta-banner__title">Still need help?</h2>
        <p class="png-cta-banner__subtitle">Call us. We'll walk you through it.</p>
      </div>
      <div class="png-cta-banner__actions">
        <a href="/pages/contact" class="png-btn-primary">Get a quote</a>
        <a href="tel:8448833308" class="png-btn-ghost--light">(844) 883-3308</a>
      </div>
    </div>
  </div>
</section>

<!-- Copy prompt JS -->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.png-dr-copy-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var pre = this.closest('.png-dr-prompt-card__body').querySelector('.png-dr-prompt-card__text');
        var text = pre ? pre.textContent : '';
        if (navigator.clipboard && text) {
          navigator.clipboard.writeText(text).then(function () {
            btn.textContent = 'Copied!';
            setTimeout(function () { btn.textContent = 'Copy prompt'; }, 2000);
          });
        }
      });
    });
    document.querySelectorAll('.png-dr-prompt-card').forEach(function (card) {
      card.addEventListener('toggle', function () {
        var toggle = this.querySelector('.png-dr-prompt-card__toggle');
        toggle.textContent = this.open ? '\u2212' : '+';
      });
    });
  });
</script>

