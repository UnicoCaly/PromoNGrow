<!-- Promo & Grow: Contact / Get a Quote -->
<section class="png-section-white">
  <div class="page-width">
    <div class="png-contact-grid">
      <!-- Form Column -->
      <div class="png-contact-form">
        <span class="png-eyebrow">{{ section.settings.eyebrow | default: 'Get a quote' }}</span>
        <h1 class="png-contact-form__heading">{{ section.settings.heading | default: 'Tell us what you need.' }}</h1>
        <p class="png-contact-form__subtext">{{ section.settings.subtext | default: 'Custom orders, bulk pricing, or questions — we respond within one business day.' }}</p>

        {%- form 'contact', id: 'ContactForm', class: 'png-form' -%}
          {%- if form.posted_successfully? -%}
            <div class="png-form__success" role="status">
              <p>Thanks! We'll be in touch within 1 business day.</p>
            </div>
          {%- endif -%}
          {%- if form.errors -%}
            <div class="png-form__error" role="alert">
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="png-form__row">
            <div class="png-form__field">
              <label for="ContactForm-name" class="png-form__label">Name</label>
              <input type="text" id="ContactForm-name" name="contact[name]" class="png-form__input" autocomplete="name" required>
            </div>
          </div>

          <div class="png-form__row png-form__row--2col">
            <div class="png-form__field">
              <label for="ContactForm-email" class="png-form__label">Email</label>
              <input type="email" id="ContactForm-email" name="contact[email]" class="png-form__input" autocomplete="email" required>
            </div>
            <div class="png-form__field">
              <label for="ContactForm-phone" class="png-form__label">Phone <span class="png-form__optional">(optional)</span></label>
              <input type="tel" id="ContactForm-phone" name="contact[phone]" class="png-form__input" autocomplete="tel">
            </div>
          </div>

          <div class="png-form__row">
            <div class="png-form__field">
              <label for="ContactForm-body" class="png-form__label">What do you need?</label>
              <textarea id="ContactForm-body" name="contact[body]" class="png-form__textarea" rows="5" required></textarea>
            </div>
          </div>

          <button type="submit" class="png-btn-primary" style="width: 100%;">
            Send message
          </button>
        {%- endform -%}
      </div>

      <!-- Info Column -->
      <div class="png-contact-info">
        <div class="png-contact-info__card">
          <h3 class="png-contact-info__title">Call us directly</h3>
          <a href="tel:8448833308" class="png-contact-info__phone">(844) 883-3308</a>
          <p class="png-contact-info__hours">Mon–Fri, 8am–5pm CST</p>
        </div>

        <div class="png-contact-info__badges">
          <div class="png-trust-bar__item">
            <span class="png-trust-dot" aria-hidden="true"></span>
            <span>5-day delivery guaranteed</span>
          </div>
          <div class="png-trust-bar__item">
            <span>Free proof on every order</span>
          </div>
          <div class="png-trust-bar__item">
            <span>Made in the USA</span>
          </div>
          <div class="png-trust-bar__item">
            <span class="png-trust-bar__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span>4.8 from 19 reviews</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Form",
  "class": "png-contact-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Get a quote"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tell us what you need."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Custom orders, bulk pricing, or questions — we respond within one business day."
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
